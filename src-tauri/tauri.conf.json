{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Financial Analyzer",
  "version": "0.1.0",
  "identifier": "com.financial.analyzer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label":           "main",
        "title":           "Financial Analyzer",
        "width":           1400,
        "height":          860,
        "minWidth":        900,
        "minHeight":       600,
        "resizable":       true,
        "fullscreen":      false,
        "decorations":     true,
        "center":          true,
        "theme":           "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active":  true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
